{
  "name": "sports-notification-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Real-time push notifications for live football matches",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev:api": "pnpm --filter @sports/api dev",
    "dev:workers": "pnpm --filter @sports/workers dev",
    "dev:web": "pnpm --filter @sports/web dev",
    "migrate": "node --env-file-if-exists=.env scripts/migrate.js",
    "gen:vapid": "node scripts/gen-vapid-keys.js",
    "seed": "node --env-file-if-exists=.env scripts/seed.js",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint"
  },
  "devDependencies": {
    "eslint": "^9.9.0",
    "pg": "^8.12.0",
    "web-push": "^3.6.7"
  }
}
