# --- Database ---
DATABASE_URL=postgres://sports:sports@localhost:5432/sports

# --- Cache / Queue ---
REDIS_URL=redis://localhost:6379

# --- Auth ---
JWT_SECRET=change-me-to-a-long-random-string
# Cookie name for the auth JWT
AUTH_COOKIE_NAME=sports_token

# --- Sports data API ---
# API-Football (RapidAPI or direct) or TheSportsDB key
SPORTS_API_KEY=
SPORTS_API_BASE_URL=https://v3.football.api-sports.io

# --- Web Push (VAPID) --- generate with: pnpm gen:vapid
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# --- Runtime ---
API_PORT=4000
# How often the poller ticks, in ms
POLL_INTERVAL_MS=20000
# Comma-separated origins allowed by the API CORS layer
CORS_ORIGIN=http://localhost:5173
NODE_ENV=development
LOG_LEVEL=info
