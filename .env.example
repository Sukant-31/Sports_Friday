# --- Database ---
DATABASE_URL=postgresql://sports:sports@localhost:5432/sports

# --- Cache / Queue (Redis + arq) ---
REDIS_URL=redis://localhost:6379

# --- Auth ---
JWT_SECRET=change-me-to-a-long-random-string
# Cookie name for the auth JWT
AUTH_COOKIE_NAME=sports_token

# --- Sports data API ---
# API-Football (direct) or TheSportsDB key
SPORTS_API_KEY=
SPORTS_API_BASE_URL=https://v3.football.api-sports.io

# --- Web Push (VAPID) --- generate with: python backend/scripts/gen_vapid.py
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# --- Runtime ---
API_PORT=8000
# How often the poller ticks, in seconds
POLL_INTERVAL_SECONDS=20
# Comma-separated origins allowed by CORS
CORS_ORIGIN=http://localhost:5173
ENV=development
LOG_LEVEL=INFO
